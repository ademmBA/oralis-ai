pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                git branch: 'main',
                url: 'https://github.com/ademmBA/oralis-ai.git'
            }
        }

        stage('Docker Build Backend') {
            steps {
                sh 'docker build -t pi-backend:latest ./backend'
            }
        }

        stage('Docker Run Backend') {
            steps {
                sh '''
                docker stop pi-backend || exit 0
                docker rm pi-backend || exit 0
                docker run -d --name pi-backend -p 3000:3000 pi-backend:latest
                '''
            }
        }
    }
}